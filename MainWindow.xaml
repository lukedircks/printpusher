<Window x:Class="PrintPusher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PrintPusher"
        Width="900" Height="700"
        MinWidth="600" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Centered container to constrain width -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Center" MaxWidth="720" Width="Auto">
            <GroupBox Header="Connection" Margin="0,0,0,8">
                <Grid Margin="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="220" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="90" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Label Grid.Column="0" VerticalAlignment="Center" Margin="0,0,6,0">Printer IP</Label>
                    <TextBox Grid.Column="1" Name="PrinterIpTextBox" VerticalAlignment="Center" Width="220" />

                    <Label Grid.Column="3" VerticalAlignment="Center" Margin="6,0,6,0">Port</Label>
                    <TextBox Grid.Column="4" Name="PortTextBox" VerticalAlignment="Center" Width="90" Text="9100" />

                    <Button Grid.Column="6" Name="TestConnectionButton" Content="Test Connection" HorizontalAlignment="Left" Padding="8,4" Click="TestConnectionButton_Click" />
                </Grid>
            </GroupBox>
        </StackPanel>

        <!-- Main work area -->
        <StackPanel Grid.Row="1" HorizontalAlignment="Center" MaxWidth="720" Width="Auto">
            <GroupBox Header="Work" Margin="0,0,0,8">
                <Grid Margin="8">
                    <TabControl Name="MainTabControl">
                        <TabItem Header="Builder">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <Grid Margin="4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160" />
                                        <ColumnDefinition Width="420" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Label Grid.Row="0" Grid.Column="0" VerticalAlignment="Center">Barcode Value</Label>
                                    <TextBox Grid.Row="0" Grid.Column="1" Name="BarcodeTextBox" Width="380" TextChanged="InputChanged" />

                                    <Label Grid.Row="1" Grid.Column="0" VerticalAlignment="Center">Human Readable Text</Label>
                                    <TextBox Grid.Row="1" Grid.Column="1" Name="TextTextBox" Width="380" TextChanged="InputChanged" />

                                    <Label Grid.Row="2" Grid.Column="0" VerticalAlignment="Center">Width (inches)</Label>
                                    <TextBox Grid.Row="2" Grid.Column="1" Name="WidthTextBox" Width="100" Text="2" TextChanged="InputChanged" />

                                    <Label Grid.Row="3" Grid.Column="0" VerticalAlignment="Center">Height (inches)</Label>
                                    <TextBox Grid.Row="3" Grid.Column="1" Name="HeightTextBox" Width="100" Text="3" TextChanged="InputChanged" />

                                    <Label Grid.Row="4" Grid.Column="0" VerticalAlignment="Top">Rotation</Label>
                                    <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button Name="RotateLeftButton" Content="Rotate Left" Width="90" Margin="0,0,8,0" Padding="4,2" Click="RotateLeftButton_Click" />
                                        <Button Name="RotateRightButton" Content="Rotate Right" Width="90" Margin="0,0,8,0" Padding="4,2" Click="RotateRightButton_Click" />
                                        <Label Name="RotationLabel" Content="Rotation: 0°" VerticalAlignment="Center" />
                                    </StackPanel>

                                    <Label Grid.Row="5" Grid.Column="0" />
                                    <CheckBox Grid.Row="5" Grid.Column="1" Name="AutoIncrementCheckBox" Content="Auto Increment" VerticalAlignment="Center" />

                                    <Label Grid.Row="6" Grid.Column="0" VerticalAlignment="Center">Start Value</Label>
                                    <TextBox Grid.Row="6" Grid.Column="1" Name="StartValueTextBox" Width="100" Text="1" TextChanged="InputChanged" />

                                    <Label Grid.Row="7" Grid.Column="0" VerticalAlignment="Center">Count</Label>
                                    <TextBox Grid.Row="7" Grid.Column="1" Name="CountTextBox" Width="100" Text="1" TextChanged="InputChanged" />

                                    <Label Grid.Row="8" Grid.Column="0" VerticalAlignment="Top">Preview</Label>
                                    <Border Grid.Row="8" Grid.Column="1" BorderBrush="Black" BorderThickness="1" Width="300" Height="200" HorizontalAlignment="Left" Background="White">
                                        <Canvas Name="PreviewCanvas" Background="White" />
                                    </Border>

                                    <Button Grid.Row="9" Grid.Column="1" Name="GeneratePrintButton" Content="Generate and Print" HorizontalAlignment="Left" Padding="8,4" Margin="0,12,0,0" Click="GeneratePrintButton_Click" />
                                </Grid>
                            </ScrollViewer>
                        </TabItem>

                        <TabItem Header="Raw ZPL">
                            <StackPanel Margin="6">
                                <TextBox Name="RawZplTextBox" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Width="560" Height="220" />
                                <Button Name="SendRawZplButton" Content="Send Raw ZPL" HorizontalAlignment="Left" Padding="8,4" Margin="0,8,0,0" Click="SendRawZplButton_Click" />
                            </StackPanel>
                        </TabItem>
                    </TabControl>
                </Grid>
            </GroupBox>
        </StackPanel>

        <!-- Status bar -->
        <Border Grid.Row="2" Padding="6,6,6,6">
            <Grid MaxWidth="720" HorizontalAlignment="Center">
                <Label Name="StatusLabel" Content="Ready" VerticalAlignment="Center" />
            </Grid>
        </Border>
    </Grid>
</Window>
